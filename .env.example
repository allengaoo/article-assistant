# ── WeChat Official Account (required for /api/publish & CLI publish) ──────────
# mp.weixin.qq.com → Settings → Developer → Basic Configuration
WX_APPID=
WX_APPSECRET=
# 默认封面素材 media_id（可选）：正文无图时自动使用，避免推送失败
# 获取方式：用微信公众号后台上传一张默认封面，复制其 media_id 填入
WX_DEFAULT_THUMB_MEDIA_ID=

# ── Alibaba Cloud Bailian / DashScope (required for webapp AI features) ───────
DASHSCOPE_API_KEY=

# ── Webapp access control ─────────────────────────────────────────────────────
# 兼容期：旧版单密码登录（账号留空时仍可用）；建议逐步迁移到多用户账号
ACCESS_TOKEN=
MASTER_KEY=
# 首次启动且无用户时，自动创建管理员（SQLite data/app.db）
ADMIN_LOGIN=
ADMIN_PASSWORD=

# ── Server port (default 3000; Nginx proxies 443 → 3000) ─────────────────────
PORT=3000

# ── Feishu (local CLI only — do NOT deploy to server) ─────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ── Skywork AI (optional — image generation CLI) ──────────────────────────────
SKYWORK_API_KEY=

# ── Data directory (default: ./data next to webapp/) ─────────────────────────
# DATA_DIR=/root/gzh-publish/data

# ── Remote deploy (local only — do NOT commit real values) ────────────────────
# 复制到 .env 后填写真实 ECS 地址；your-server 只是占位符，不能直接使用
DEPLOY_HOST=root@your-server
DEPLOY_DIR=/root/gzh-publish
