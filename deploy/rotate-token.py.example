#!/usr/bin/env python3
"""Weekly ACCESS_TOKEN rotation example. Copy to server and set MASTER_KEY in .env."""
import re
import secrets
import subprocess
from pathlib import Path

ENV_PATH = Path('/root/gzh-publish/webapp/.env')

def main():
    text = ENV_PATH.read_text()
    new_token = str(secrets.randbelow(900000) + 100000)
    updated, n = re.subn(r'^ACCESS_TOKEN=.*$', f'ACCESS_TOKEN={new_token}', text, flags=re.M)
    if n == 0:
        updated = text.rstrip() + f'\nACCESS_TOKEN={new_token}\n'
    ENV_PATH.write_text(updated)
    subprocess.run(['pm2', 'restart', 'gzh-webapp'], check=False)
    print(f'New ACCESS_TOKEN: {new_token}')

if __name__ == '__main__':
    main()
