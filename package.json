{
  "name": "article-assistant",
  "version": "1.0.0",
  "description": "Mobile-first article & PRD assistant with WeChat draft and Feishu publishing",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "NODE_ENV=test node --test 'tests/**/*.test.mjs'",
    "test:unit": "NODE_ENV=test node --test tests/*.test.mjs",
    "test:e2e": "NODE_ENV=test node --test tests/e2e/*.test.mjs",
    "start": "npm --prefix webapp start",
    "dev": "npm --prefix webapp run dev",
    "publish": "node scripts/publish.mjs",
    "dry-run": "node scripts/publish.mjs",
    "feishu-publish": "node scripts/feishu-publish.mjs",
    "remote-publish": "bash scripts/remote-publish.sh",
    "remote-deploy": "bash scripts/remote-deploy.sh"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0"
  }
}
